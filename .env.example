# ====================================================
# DOCKER
# ====================================================

HOST_WORKSPACE_PATH=""

# ====================================================
# LLM
# ====================================================

# Можно использовать любой OpenAI-совместимый API (OpenAI, OpenRouter, VLLM, Local)
LLM_API_URL="https://openrouter.ai/api/v1" # Укажите URL вашего LLM API

# Можно указать сколько угодно ключей (LLM_API_KEY_1, LLM_API_KEY_2 и т.д.) - ротатор их подхватит
LLM_API_KEY_1=""
LLM_API_KEY_2=""

# ====================================================
# TELEGRAM
# ====================================================

# Для классического бота (Aiogram)
TELEGRAM_BOT_TOKEN=

# Для юзербота (Telethon). Берется с my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ====================================================
# GITHUB
# ====================================================

# Personal Access Token (Classic или Fine-grained) с правами на чтение/запись репозиториев
GITHUB_TOKEN_AGENT=

# ====================================================
# REDDIT
# ====================================================

# Создается в https://www.reddit.com/prefs/apps (Тип приложения: script)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ====================================================
# HABR
# ====================================================

# Вытаскивается из браузера (Application -> Cookies) после авторизации на Хабре
HABR_CONNECT_SID=
HABR_CSRF_TOKEN=

# ====================================================
# EMAIL (IMAP / SMTP)
# ====================================================

EMAIL_ADDRESS=
# Для Gmail/Yandex нужно создать "Пароль приложения" (App Password)
EMAIL_PASSWORD=

EMAIL_IMAP_SERVER=
EMAIL_IMAP_PORT=
EMAIL_SMTP_SERVER=
EMAIL_SMTP_PORT=

# ====================================================
# WEB SEARCH (Google)
# ====================================================

# API ключ из Google Cloud Console (Custom Search API)
GOOGLE_API_KEY=
# ID поисковой системы (Programmable Search Engine)
GOOGLE_SEARCH_ENGINE_ID=

# ====================================================
# БАЗЫ ДАННЫХ И ИНФРАСТРУКТУРА
# ====================================================
# Рекомендуется не менять

RABBITMQ_URL="amqp://guest:guest@aaf_rabbitmq:5672/"
SQL_DB_URL="postgresql+asyncpg://postgres:postgres@aaf_postgres:5432/agent_db"