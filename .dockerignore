# ==========================================
# Исключения для Docker Build Context
# ==========================================

# Системное и IDE
.git/
.gitignore
.idea/
.vscode/
__pycache__/
*.py[cod]
*$py.class
.DS_Store
Thumbs.db

# Виртуальные окружения
.venv/
venv/
env/

# Конфиги / настройки / ключи
.env
agent/config/settings.yaml
agent/config/interfaces.yaml
**/api_keys_state.json

# Базы данных и сессии
agent/data/chroma_db/
agent/data/kuzu_db/
agent/data/telegram_sessions/
agent/data/shadow_backups/
*.sqlite
*.db

# Тяжелые локальные ИИ-модели
src/l00_utils/local/

# Sandbox (Оставляем только .gitkeep для сохранения структуры папок)
agent/sandbox/*
!agent/sandbox/.gitkeep
agent/temp/*
!agent/temp/.gitkeep

# Разрешаем Git видеть .gitkeep во всех пустых папках
!**/.gitkeep

# Логи
logs/

# Скрипты / утилиты
scripts/
all_code.txt
copy_all_code.py